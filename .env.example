# =============================================================================
# Groww Reviews Analyser - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual API keys
# For Render deployment, add these as Environment Variables in the dashboard

# =============================================================================
# LLM API KEYS (Required)
# =============================================================================

# Groq API Key - Get from https://console.groq.com/keys
# Used for: Theme extraction and classification
GROQ_API_KEY=your_groq_api_key_here

# Groq Fallback API Key (optional - for rate limit handling)
GROQ_API_KEY_FALLBACK=your_groq_fallback_api_key_here

# Google Gemini API Key - Get from https://aistudio.google.com/app/apikey
# Used for: Insight generation
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# EMAIL CONFIGURATION (Required for email delivery)
# =============================================================================

# SMTP Server Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# For Gmail: Use App Password, not your regular password
# Generate at: https://myaccount.google.com/apppasswords

# =============================================================================
# API SECURITY (Required for GitHub Actions scheduler)
# =============================================================================

# API Token for authenticating scheduled requests
# Generate a secure random token
API_TOKEN=your_secure_api_token_here

# =============================================================================
# OPTIONAL SETTINGS
# =============================================================================

# Database URL (defaults to SQLite if not set)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis URL (for task queue - optional)
# REDIS_URL=redis://localhost:6379/0

# Debug mode
DEBUG=False
