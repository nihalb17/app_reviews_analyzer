# Groww Reviews Analyser - Environment Variables
# Copy this file to .env and fill in your actual API keys

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# SQLite (default for local development)
DATABASE_URL=sqlite:///./groww_reviews.db

# PostgreSQL (for production)
# DATABASE_URL=postgresql://username:password@localhost:5432/groww_reviews

# =============================================================================
# REDIS CONFIGURATION (for Celery task queue)
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# LLM API KEYS
# =============================================================================

# Groq API Key - Get from https://console.groq.com/keys
# Used for: Theme extraction and classification (fast, cost-effective)
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Key - Get from https://aistudio.google.com/app/apikey
# Used for: Insight generation (gemini-2.0-flash model)
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# EMAIL CONFIGURATION (SMTP)
# =============================================================================
# SMTP Server Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# For Gmail: Use App Password, not your regular password
# Generate at: https://myaccount.google.com/apppasswords

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
# Debug mode (True/False)
DEBUG=True

# App name
APP_NAME=Groww Reviews Analyser

# =============================================================================
# PLAY STORE SETTINGS
# =============================================================================
# Groww app package name (don't change unless testing different app)
APP_PACKAGE=com.nextbillion.groww

# Maximum reviews to fetch per request
MAX_REVIEWS=1000

# =============================================================================
# REVIEW FILTERING SETTINGS
# =============================================================================
# Minimum words required in a review
MIN_WORDS=5

# Language detection confidence threshold (0.0 - 1.0)
LANG_CONFIDENCE=0.9
